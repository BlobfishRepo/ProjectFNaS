  hintsPanel: {fileID: 1197220345}
  continueCampaignButton: {fileID: 474447572}
  continueCampaignButtonText: {fileID: 144485307}
  continueLabelFormat: Continue Night {0}
  customNightButton: {fileID: 2140518820}
  customNightButtonText: {fileID: 240925636}
  customNightLockedLabel: Custom Night (Locked)
  customNightUnlockedLabel: Custom Night
  star1Object: {fileID: 812765424}
  star2Object: {fileID: 1835528293}
  star3Object: {fileID: 419788328}
  backgroundObject: {fileID: 1150219463}
  backgroundImage: {fileID: 1150219464}
  defaultStalkerBackground: {fileID: 21300000, guid: 97417192ac637514d9bb8c1d3b05d263, type: 3}
  randomMainMenuBackgrounds:
  - {fileID: 21300000, guid: 97417192ac637514d9bb8c1d3b05d263, type: 3}
  - {fileID: 21300000, guid: 12ba597dddaa6424db3669eb9b413f39, type: 3}
  - {fileID: 21300000, guid: d5352cc52e227ff45999082d3e0230e3, type: 3}
  infoPopup: {fileID: 740079464}
  mainMenuInfoText: 'Welcome to our Five Nights at Silvers'' project. There are two
    main modes:

    1. New Game takes you to the classic Nights 1-5 experience,
    and is the recommended way to play.

    2. Presentation Night is a single night
    experience to be used to present the project.


    More information mechanics
    on can be seen by pressing [Left Click] on the post-it notes in-game. If you
    need (or want) more detailed information, use the "Hints" menu.


    There are
    more settings in the Settings Gear, including brightness, volume, and control
    tweaks. '
  presentationInfoText: 'Presentation Night has the following settings:

    1. Doing
    the assignment in order to beat the night takes 120 seconds.

    2. Each 20%
    of the assignment (24 seconds) progresses the stage, which progressively adds
    entities to the night and then makes existing entities more aggressive.

    3.The
    first 20% has NO ENTITIES, so feel free to explore the apartment.


    In order
    to progress, use [R] at the desk to write on the paper. Post-it notes will appear
    throughout the night. While you are reading a post-it note, you cannot die, so
    make sure to understand what the note is saying.


    There is also a field
    to input custom text to show off the rendering. Ideally, use a large block of
    text.


    Good luck. '
  devSettingsChangedIndicator: {fileID: 1806962397}
  funSettingsEnabledIndicator: {fileID: 1596655531}
